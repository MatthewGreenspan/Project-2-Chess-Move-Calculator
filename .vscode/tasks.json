{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "make",
      "options": {
        "cwd": "${workspaceFolder}/cpp"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "run",
      "type": "shell",
      "command": "make run",
      "options": {
        "cwd": "${workspaceFolder}/cpp"
      }
    }
  ]
}
